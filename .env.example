# Server runtime settings
NODE_ENV=production
PORT=3000

# Required for AI analyst chat. Keep this server-side only. Do not expose it in Vite/client env vars.
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash

# Optional: enables a simple HTTP Basic Auth gate in production.
# Username can be anything; password must match this value.
# For stronger protection, use Cloudflare Access and leave this unset.
ALPHA_ACCESS_PASSWORD=replace_with_long_random_password

# Optional: public URL of your alpha deployment.
APP_URL=https://alpha.yourdomain.com
